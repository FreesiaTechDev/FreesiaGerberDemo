<Window x:Class="FreesiaGerberDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:FreesiaGerberDemo.Converters"
        xmlns:views="clr-namespace:FreesiaGerberDemo.Views"
        mc:Ignorable="d"
        Title="Freesia Gerber Demo" Height="800" Width="1280"
        MinHeight="560" MinWidth="900"
        WindowStartupLocation="CenterScreen">
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="File"
                      Margin="8,0,0,0"
                      Padding="10,4">
                <MenuItem Header="Load RS274X File"
                          Click="OnLoadFileMenuItemClick" />
                <MenuItem Header="Load Folder"
                          Click="OnLoadFolderMenuItemClick" />
            </MenuItem>
            <MenuItem Header="License"
                      Padding="10,4"
                      Click="OnLicenseMenuItemClick" />
        </Menu>
        <StatusBar DockPanel.Dock="Bottom">
            <DockPanel Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=StatusBar}}">
                <TextBlock x:Name="StatusDetailTextBlock"
                           Text=""
                           Margin="16,0,12,0"
                           HorizontalAlignment="Right"
                           DockPanel.Dock="Right" />
                <TextBlock x:Name="StatusTextBlock"
                           Text="Ready"
                           Margin="0,0,12,0"
                           TextTrimming="CharacterEllipsis" />
            </DockPanel>
        </StatusBar>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="220" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Margin="8,8,2,8"
                    BorderBrush="#D0D7DE" BorderThickness="1"
                    Grid.Column="0">
                <DockPanel>
                    <Border BorderBrush="#005A9E" BorderThickness="0,0,0,1"
                            Background="#007ACC"
                            Padding="12,6"
                            DockPanel.Dock="Top">
                        <TextBlock x:Name="GerberTitleTextBlock"
                                   Text="Gerber"
                                   Foreground="#FFFFFF"
                                   FontSize="13"
                                   FontWeight="SemiBold" />
                    </Border>
                    <TreeView x:Name="DataTreeView"
                              BorderBrush="#D0D7DE"
                              BorderThickness="0,1,0,0"
                              SelectedItemChanged="OnDataTreeViewSelectedItemChanged">
                        <TreeView.Resources>
                            <Style TargetType="{x:Type TreeViewItem}">
                                <Setter Property="IsExpanded" Value="True" />
                            </Style>
                        </TreeView.Resources>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Converter={x:Static converters:MiscConverter.Instance}, ConverterParameter=GerberSteps}">
                                <TextBlock Text="{Binding Converter={x:Static converters:MiscConverter.Instance}, ConverterParameter=GerberHeader}"
                                           Padding="5"
                                           ToolTip="{Binding Converter={x:Static converters:MiscConverter.Instance}, ConverterParameter=GerberPath}" />
                                <HierarchicalDataTemplate.ItemTemplate>
                                    <HierarchicalDataTemplate ItemsSource="{Binding Converter={x:Static converters:MiscConverter.Instance}, ConverterParameter=StepLayers}">
                                        <TextBlock Text="{Binding Converter={x:Static converters:MiscConverter.Instance}, ConverterParameter=StepHeader}" 
                                                   Padding="5"/>
                                        <HierarchicalDataTemplate.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Converter={x:Static converters:MiscConverter.Instance}, ConverterParameter=LayerHeader}"
                                                           Padding="5"/>
                                            </DataTemplate>
                                        </HierarchicalDataTemplate.ItemTemplate>
                                    </HierarchicalDataTemplate>
                                </HierarchicalDataTemplate.ItemTemplate>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </DockPanel>
            </Border>
            <GridSplitter Width="10"
                          Margin="-5,0"
                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                          Background="Transparent"
                          ResizeBehavior="PreviousAndNext"
                          Panel.ZIndex="100"
                          Grid.Column="1" />
            <TabControl x:Name="MainTabControl"
                        Margin="2,8,8,8"
                        Grid.Column="2"
                        SelectionChanged="OnMainTabControlSelectionChanged">
                <TabItem Header="Render Preview"
                         Padding="10,7,10,6">
                    <views:RenderPreviewView x:Name="RenderPreviewView" />
                </TabItem>
                <TabItem x:Name="VisualTreeTabItem"
                         Header="Visual Tree"
                         Padding="10,7,10,6">
                    <views:VisualTreePreviewView x:Name="VisualTreePreviewView" />
                </TabItem>
            </TabControl>
        </Grid>
    </DockPanel>
</Window>
